#include "ORDER.h"


ORDER::ORDER(const char* p, const char* r, int s)
{
    strcpy_s(payer, p);

    strcpy_s(receiver, r);

    sum = s;
}


ORDER::ORDER()
{
    payer[0] = '\0';

    receiver[0] = '\0';

    sum = 0;
}


// сравнение
bool ORDER::operator>(const ORDER& b)
{
    return strcmp(payer, b.payer) > 0;
}

bool ORDER::operator<(const ORDER& b)
{
    return strcmp(payer, b.payer) < 0;
}

bool ORDER::operator==(const ORDER& b)
{
    return strcmp(payer, b.payer) == 0;
}



// вывод
ostream& operator<<(ostream& os, const ORDER& m)
{
    os << m.payer << " "
        << m.receiver << " "
        << m.sum;

    return os;
}



// ввод
istream& operator>>(istream& is, ORDER& m)
{
    is >> m.payer
        >> m.receiver
        >> m.sum;

    return is;
}



char* ORDER::getPayer()
{
    return payer;
}

int ORDER::getSum()
{
    return sum;
}


void ORDER::print()
{
    cout << payer << " "
        << receiver << " "
        << sum << endl;
}

