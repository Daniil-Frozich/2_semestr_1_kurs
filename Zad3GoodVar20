// ---------------- BUBBLE SORT ----------------
template <class T>
void bubbleSort(T* arr, int n)
{
    for (int i = 0; i < n - 1; i++)
    {
        for (int j = 0; j < n - i - 1; j++)
        {
            // сравнение объектов через operator >
            if (arr[j].operator>(arr[j + 1]))
            {
                T temp = arr[j];

                arr[j] = arr[j + 1];

                arr[j + 1] = temp;
            }
        }
    }
}



// ---------------- SELECTION SORT ----------------
template <class T>
void selectionSort(T* arr, int n)
{
    for (int i = 0; i < n - 1; i++)
    {
        int min = i;

        for (int j = i + 1; j < n; j++)
        {
            // сравнение объектов
            if (arr[min].operator>(arr[j]))
            {
                min = j;
            }
        }

        T temp = arr[i];

        arr[i] = arr[min];

        arr[min] = temp;
    }
}



// ---------------- INSERTION SORT ----------------
template <class T>
void insertionSort(T* arr, int n)
{
    for (int i = 1; i < n; i++)
    {
        T x = arr[i];

        int j = i - 1;

        // пока элемент слева больше
        while (j >= 0 && arr[j].operator>(x))
        {
            arr[j + 1] = arr[j];

            j--;
        }

        arr[j + 1] = x;
    }
}



// ---------------- SHELL SORT ----------------
template <class T>
void shellSort(T* arr, int n)
{
    for (int step = n / 2; step > 0; step = step / 2)
    {
        for (int i = step; i < n; i++)
        {
            T x = arr[i];

            int j = i;

            while (j >= step &&
                arr[j - step].operator>(x))
            {
                arr[j] = arr[j - step];

                j = j - step;
            }

            arr[j] = x;
        }
    }
}



// ---------------- QUICK SORT ----------------
template <class T>
void quickSort(T* arr, int left, int right)
{
    int k = (left + right) / 2;

    // опорный элемент
    T x = arr[k];

    int i = left;

    int j = right;

    do
    {
        // поиск слева
        while (arr[i].operator<(x))
        {
            i++;
        }

        // поиск справа
        while (arr[j].operator>(x))
        {
            j--;
        }

        // обмен элементов
        if (i <= j)
        {
            T temp = arr[i];

            arr[i] = arr[j];

            arr[j] = temp;

            i++;

            j--;
        }

    } while (i <= j);


    // рекурсия слева
    if (left < j)
    {
        quickSort(arr, left, j);
    }


    // рекурсия справа
    if (i < right)
    {
        quickSort(arr, i, right);
    }
}



// ---------------- QSORT C ----------------
static int compareOrder(const void* x, const void* y)
{
    ORDER* a = (ORDER*)x;

    ORDER* b = (ORDER*)y;

    // сравнение payer
    return strcmp(a->getPayer(),
        b->getPayer());
}

