#pragma once
#include <iostream>
#include <fstream>
#include <string.h>

using namespace std;

class ORDER
{
private:
    char payer[20];
    char receiver[20];
    int sum;

public:

    ORDER(const char* p, const char* r, int s);
    ORDER();

    // сравнение
    bool operator>(const ORDER& b);
    bool operator<(const ORDER& b);
    bool operator==(const ORDER& b);

    // работа с файлами
    friend ostream& operator<<(ostream& os, const ORDER& m);
    friend istream& operator>>(istream& is, ORDER& m);

    // поиск
    char* getPayer();

    int getSum();

    // вывод
    void print();
};

