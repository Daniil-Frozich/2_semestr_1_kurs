#include "List.h"

List::List()
{
    head = NULL;
}

bool List::empty()
{
    return head == NULL;
}

void List::addBegin(ORDER x)
{
    Node* t = new Node(x);

    t->next = head;

    head = t;
}

void List::addEnd(ORDER x)
{
    Node* t = new Node(x);

    if (empty())
    {
        head = t;

        return;
    }

    Node* p = head;

    while (p->next != NULL)
    {
        p = p->next;
    }

    p->next = t;
}

bool List::find(char* payer)
{
    Node* p = head;

    while (p != NULL)
    {
        if (strcmp(p->data.getPayer(),
            payer) == 0)
        {
            return true;
        }

        p = p->next;
    }

    return false;
}

void List::remove(char* payer)
{
    if (empty())
    {
        return;
    }

    if (strcmp(head->data.getPayer(),
        payer) == 0)
    {
        Node* t = head;

        head = head->next;

        delete t;

        return;
    }

    Node* p = head;

    while (p->next != NULL)
    {
        if (strcmp(p->next->data.getPayer(),
            payer) == 0)
        {
            Node* t = p->next;

            p->next = t->next;

            delete t;

            return;
        }

        p = p->next;
    }
}

void List::addSort(ORDER x)
{
    Node* t = new Node(x);

    if (empty() || x < head->data)
    {
        t->next = head;

        head = t;

        return;
    }

    Node* p = head;

    while (p->next != NULL &&
        p->next->data < x)
    {
        p = p->next;
    }

    t->next = p->next;

    p->next = t;
}

void List::print()
{
    Node* p = head;

    while (p != NULL)
    {
        cout << p->data << endl;

        p = p->next;
    }
}

