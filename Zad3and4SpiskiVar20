#include "ORDER.h"

ORDER::ORDER()
{
    payer[0] = '\0';

    receiver[0] = '\0';

    sum = 0;
}

ORDER::ORDER(const char* p,
    const char* r,
    int s)
{
    strcpy_s(payer, p);

    strcpy_s(receiver, r);

    sum = s;
}


// ---------------- СРАВНЕНИЕ ----------------
bool ORDER::operator>(const ORDER& b)
{
    return strcmp(payer,
        b.payer) > 0;
}

bool ORDER::operator<(const ORDER& b)
{
    return strcmp(payer,
        b.payer) < 0;
}

bool ORDER::operator==(const ORDER& b)
{
    return strcmp(payer,
        b.payer) == 0;
}



// ---------------- ВЫВОД ----------------
ostream& operator<<(ostream& os,
    const ORDER& m)
{
    os << m.payer << " "
        << m.receiver << " "
        << m.sum;

    return os;
}



// ---------------- ВВОД ----------------
istream& operator>>(istream& is,
    ORDER& m)
{
    is >> m.payer
        >> m.receiver
        >> m.sum;

    return is;
}



// ---------------- GET ----------------
char* ORDER::getPayer()
{
    return payer;
}

int ORDER::getSum()
{
    return sum;
}



// ---------------- PRINT ----------------
void ORDER::print()
{
    cout << payer << " "
        << receiver << " "
        << sum << endl;
}

