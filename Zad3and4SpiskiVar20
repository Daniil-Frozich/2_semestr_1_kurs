#include "ORDER.h"
#include "Sort.h"
#include "List.h"

int main()
{
    ifstream in("text.txt");

    if (!in)
    {
        cout << "File error\n";

        return 1;
    }

    ORDER arr[10];

    int n = 0;

    while (in >> arr[n])
    {
        n++;
    }

    in.close();

    cout << "Before sort:\n\n";

    for (int i = 0; i < n; i++)
    {
        cout << arr[i] << endl;
    }

    bubbleSort(arr, n);

    cout << "\nAfter bubble sort:\n\n";

    for (int i = 0; i < n; i++)
    {
        cout << arr[i] << endl;
    }

    qsort(arr, 0, n - 1);

    cout << "\nAfter quick sort:\n\n";

    for (int i = 0; i < n; i++)
    {
        cout << arr[i] << endl;
    }

    ::qsort(arr,
        n,
        sizeof(ORDER),
        ORDER::compORDER);

    cout << "\nAfter library qsort:\n\n";

    for (int i = 0; i < n; i++)
    {
        cout << arr[i] << endl;
    }

    ofstream out("orders.bin",
        ios::binary);

    out.write((char*)arr,
        n * sizeof(ORDER));

    out.close();

    ORDER temp[10];

    ifstream inBin("orders.bin",
        ios::binary);

    inBin.read((char*)temp,
        n * sizeof(ORDER));

    inBin.close();

    cout << "\nFrom binary file:\n\n";

    for (int i = 0; i < n; i++)
    {
        cout << temp[i] << endl;
    }

    char s[20];

    cout << "\nInput payer: ";

    cin >> s;

    bool found = false;

    for (int i = 0; i < n; i++)
    {
        if (strcmp(temp[i].getPayer(),
            s) == 0)
        {
            cout << "Sum: "
                << temp[i].getSum()
                << endl;

            found = true;
        }
    }

    if (!found)
    {
        cout << "Not found\n";
    }

    List lst;

    for (int i = 0; i < n; i++)
    {
        lst.addEnd(arr[i]);
    }

    cout << "\nLIST:\n\n";

    lst.print();

    if (lst.find(s))
    {
        cout << "\nFound in list\n";
    }
    else
    {
        cout << "\nNot found in list\n";
    }

    lst.remove(s);

    cout << "\nAfter remove:\n\n";

    lst.print();

    ORDER x("11111",
        "22222",
        5000);

    lst.addSort(x);

    cout << "\nAfter addSort:\n\n";

    lst.print();

    return 0;
}