#include <fstream>
#include <string.h>

using namespace std;

class ORDER
{
private:

    char payer[20];
    char receiver[20];
    int sum;

public:

    ORDER();

    ORDER(const char* p,
        const char* r,
        int s);

    // сравнение
    bool operator>(const ORDER& b);

    bool operator<(const ORDER& b);

    bool operator==(const ORDER& b);

    // ввод вывод
    friend ostream& operator<<(ostream& os,
        const ORDER& m);

    friend istream& operator>>(istream& is,
        ORDER& m);

