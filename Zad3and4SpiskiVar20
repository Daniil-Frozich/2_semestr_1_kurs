#include "List.h"



// ---------------- NODE ----------------
Node::Node(ORDER x)
{
    data = x;

    next = NULL;
}




// ---------------- LIST ----------------
List::List()
{
    head = NULL;
}



// пуст ли список
bool List::empty()
{
    return head == NULL;
}



// добавление в начало
void List::addFirst(ORDER x)
{
    Node* temp = new Node(x);

    temp->next = head;

    head = temp;
}



// добавление в конец
void List::addLast(ORDER x)
{
    Node* temp = new Node(x);

    if (empty())
    {
        head = temp;

        return;
    }

    Node* p = head;

    while (p->next != NULL)
    {
        p = p->next;
    }

    p->next = temp;
}



// печать
void List::print()
{
    Node* p = head;

    while (p != NULL)
    {
        cout << p->data << endl;

        p = p->next;
    }
}



// поиск
bool List::find(const char* payer)
{
    Node* p = head;

    while (p != NULL)
    {
        if (strcmp(p->data.getPayer(),
            payer) == 0)
        {
            return true;
        }

        p = p->next;
    }

    return false;
}



// удаление
void List::remove(const char* payer)
{
    if (empty())
    {
        return;
    }

    Node* p = head;

    Node* prev = NULL;


    while (p != NULL)
    {
        if (strcmp(p->data.getPayer(),
            payer) == 0)
        {
            if (prev == NULL)
            {
                head = p->next;
            }
            else
            {
                prev->next = p->next;
            }

            delete p;

            return;
        }

        prev = p;

        p = p->next;
    }
}



// вставка в сортированный список
void List::addSorted(ORDER x)
{
    Node* temp = new Node(x);


    if (empty() || x < head->data)
    {
        temp->next = head;

        head = temp;

        return;
    }


    Node* p = head;


    while (p->next != NULL &&
        p->next->data < x)
    {
        p = p->next;
    }


    temp->next = p->next;

    p->next = temp;
}

